# =============================================================================
# Konfigurationsdatei - BITTE EIGENE WERTE EINTRAGEN
# Kopieren nach .env und anpassen
# =============================================================================

# Caldera API
CALDERA_API="http://localhost:8888/api/v2"
CALDERA_API_KEY="DEIN_API_KEY_HIER"

# Splunk HEC
SPLUNK_HEC="http://SPLUNK_IP:8088/services/collector/event"
SPLUNK_TOKEN="DEIN_HEC_TOKEN_HIER"
SPLUNK_HOST="SPLUNK_IP"
SPLUNK_MGMT_PORT="8089"
SPLUNK_USER="admin"
SPLUNK_PASS="DEIN_SPLUNK_PASSWORT"

# Netzwerk
CALDERA_IP="CALDERA_SERVER_IP"
TEST_NETWORK="10.99.0.0/24"
MGMT_NETWORK="10.10.0.0/24"
